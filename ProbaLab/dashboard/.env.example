VITE_SUPABASE_URL=your_supabase_url
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key
VITE_API_URL=http://localhost:8000
# Feature flag V2 (frontend refonte)
VITE_FRONTEND_V2=false
# Enable MSW mock service worker in dev (requires VITE_API_URL on localhost)
VITE_MSW_ENABLED=false
# CI Playwright only: allow MSW + __e2e_role__ in vite preview (never set in prod)
# VITE_MSW_PREVIEW=true
# VITE_E2E=true
